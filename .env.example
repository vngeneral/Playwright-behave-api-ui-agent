# ============================================================
# Environment Variables — playwright-behave-allure-ai-driven-framework
# ============================================================
# Copy this file to .env (git-ignored) and fill in values.
# NEVER commit .env or real credentials to source control.
# In CI/CD, set these as masked secret variables.
# ============================================================

# ── Run configuration ────────────────────────────────────────
BROWSER=chromium          # chromium | firefox | webkit
ENV=dev                   # dev | staging | prod
HEADLESS=true             # true | false
DEBUG=false               # true = verbose logs + page-source attachments

# ── Notification behaviour ───────────────────────────────────
# Set to "false" to send notifications even when all tests pass.
NOTIFY_ON_FAILURE=true

# ── Slack ────────────────────────────────────────────────────
# Incoming webhook URL from Slack → Your Apps → Incoming Webhooks
SLACK_WEBHOOK_URL=

# ── Microsoft Teams ──────────────────────────────────────────
# Power Automate workflow webhook URL (replaces deprecated Office 365 connector)
# Create: Power Automate → Templates → "Post to a channel when a webhook request is received"
TEAMS_WEBHOOK_URL=

# Outgoing webhook secret — from Teams channel → Manage channel → Outgoing Webhooks
# Required for RECEIVING commands from Teams (!run, !status, !help)
# Teams provides this as a base64-encoded string.
TEAMS_OUTGOING_WEBHOOK_SECRET=

# ── WhatsApp — Option A: Meta Cloud API (recommended) ────────
# From Meta Developer Console → WhatsApp → API Setup
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Token you choose when registering the webhook in Meta Developer Console
WHATSAPP_VERIFY_TOKEN=my-secure-verify-token-change-me

# ── WhatsApp — Option B: Twilio (alternative) ────────────────
# If TWILIO_ACCOUNT_SID is set it takes priority over Meta Cloud API.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox or approved number

# ── WhatsApp recipient ───────────────────────────────────────
# E.164 format, used by both Meta and Twilio providers
WHATSAPP_NOTIFY_TO=+61400000000

# ── Webhook server (integrations/webhook_server.py) ──────────
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=5000
# Random by default on each start; set for stable session cookies
WEBHOOK_SECRET_KEY=change-me-to-a-random-string

# ── TestRail integration ──────────────────────────────────────
# Results are queued locally after each scenario and pushed on demand
# via `!testrail push`.  These are required at push time, not at run time.
#
# Base URL of your TestRail instance (no trailing slash)
TESTRAIL_URL=https://yourcompany.testrail.io

# TestRail login email
TESTRAIL_USER=qa@yourcompany.com

# TestRail API key — generated under My Settings → API Keys (not your password)
TESTRAIL_API_KEY=

# Default test run ID for `!testrail push` (override per call with --run-id N)
TESTRAIL_RUN_ID=
